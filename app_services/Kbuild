#
# Kbuild for framework
#


ifeq ($(CONFIG_SERVICES_RTSP), y)
	KBUILD_DEFINES += -DSERVICES_RTSP_ON
endif

ifeq ($(CONFIG_RTSP_NO_AUDIO), y)
	KBUILD_DEFINES += -DRTSP_NO_AUDIO
endif

ifeq ($(CONFIG_SERVICES_IMAGE_VIEWER), y)
    KBUILD_DEFINES += -DSERVICES_IMAGE_VIEWER_ON
endif

ifeq ($(CONFIG_SERVICES_LIVEVIEW), y)
    KBUILD_DEFINES += -DSERVICES_LIVEVIEW_ON
endif

ifeq ($(CONFIG_SERVICES_PLAYER), y)
    KBUILD_DEFINES += -DSERVICES_PLAYER_ON
endif

ifeq ($(CONFIG_PLAYER_SUBVIDEO), y)
    KBUILD_DEFINES += -DSERVICES_PLAYER_SUBVIDEO
endif

ifeq ($(CONFIG_SERVICES_PHOTO), y)
    KBUILD_DEFINES += -DSERVICES_PHOTO_ON
endif

ifeq ($(CONFIG_SERVICES_SPEECH), y)
    KBUILD_DEFINES += -DSERVICES_SPEECH_ON
endif

ifeq ($(CONFIG_SPEECH_CARDV), y)
    KBUILD_DEFINES += -DMODEL_CARDV
endif

ifeq ($(CONFIG_ENABLE_SNAP), y)
    KBUILD_DEFINES += -DENABLE_SNAP_ON
endif

ifeq ($(CONFIG_SERVICES_SUBVIDEO), y)
    KBUILD_DEFINES += -DSERVICES_SUBVIDEO_ON
endif

ifeq ($(CONFIG_SERVICES_ADAS), y)
    KBUILD_DEFINES += -DSERVICES_ADAS_ON
endif

ifeq ($(CONFIG_ADAS_LABEL_CAR), y)
    KBUILD_DEFINES += -DSERVICES_ADAS_LABEL_CAR_ON
endif

ifeq ($(CONFIG_ADAS_LABEL_LANE), y)
    KBUILD_DEFINES += -DSERVICES_ADAS_LABEL_LANE_ON
endif

ifeq ($(CONFIG_SERVICES_QRCODE), y)
	KBUILD_DEFINES += -DSERVICES_QRCODE_ON
ifeq ($(CONFIG_ZBAR), y)
	KBUILD_DEFINES += -DENABLE_ZBAR
endif
endif

ifeq ($(CONFIG_SERVICES_VIDEO_MD), y)
	KBUILD_DEFINES += -DSERVICES_VIDEO_MD_ON
endif

ifeq ($(CONFIG_SERVICES_AUDIO), y)
	KBUILD_DEFINES += -DSERVICES_AUDIO_ON
endif

ifeq ($(CONFIG_SERVICES_FACEP), y)
	KBUILD_DEFINES += -DSERVICES_FACEP_ON
