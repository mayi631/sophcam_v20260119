# 编译输出目录
out/

# IDE配置
.vscode/
.idea/

# 编译生成的库文件(只忽略真正编译生成的)
out/**/*.a
out/**/*.so
components/AIsdk/.deps/
components/*/build/
applications/tools/awtkres/scripts/__pycache__/*.pyc

components/comps_install/arm-none-linux-musleabihf/cvi_mpi/lib/
components/comps_install/arm-none-linux-musleabihf/cvi_tdl_sdk/lib/
components/comps_install/arm-none-linux-musleabihf/hal/lib/
components/comps_install/arm-none-linux-musleabihf/mapi/lib/
components/comps_install/arm-none-linux-musleabihf/cvi_mpi/include/
components/comps_install/arm-none-linux-musleabihf/cvi_tdl_sdk/include/

oss/awtkcode/awtk-linux-fb/build/
oss/ffmpeg/build/
oss/lvgl/build/
oss/csi2d/build/
oss/thttpd/build/

# 编译生成的目标文件
*.o
*.d
*.cmd
built-in.o

# 特定编译产物目录
app_services/obj/
applications/*/obj/
components/*/obj/

# UI编译产物（仅忽略turnkey生成的build目录）
applications/dashcam/ui/*/turnkey/build/
applications/dashcam/ui/*/build/

# OSS第三方库编译产物
oss/awtkcode/awtk/build/
oss/ffmpeg/install/
oss/csi2d/build/
oss/thttpd/build/

# LVGL编译产物（特定库文件）
oss/lvgl/install/arm-none-linux-musleabihf/lib/liblvgl.a
oss/lvgl/install/arm-none-linux-musleabihf/lib/liblvgl_demos.a
oss/lvgl/install/arm-none-linux-musleabihf/lib/liblvgl_examples.a
oss/lvgl/install/arm-none-linux-musleabihf/lib/liblvgl_thorvg.a

# 应用和服务的特定编译库
app_services/lib/libapp_service.a
applications/manager/lib/libapp_mng.a
applications/manager/lib/libapp_mng.so

# 可执行文件(忽略编译输出,保留模板和配置文件)
**/out/bin/*
**/app_services/bin/*
**/applications/*/bin/*
!**/bin/.gitkeep



# 构建标记
*.stamp
.sconsign.dblite
.sconsign.dblite2

# 日志文件
*.log

# 临时文件
*~
.*.swp
.DS_Store
Thumbs.db
